generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
}

enum Role {
  CITIZEN
  ENGINEER
  DEPARTMENT
  SUPERVISOR
  ADMIN
  SUPER_ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  role      Role     @default(CITIZEN)
  phoneNumber String?
  fullName  String?
  isActive  Boolean  @default(true)
  isVerified Boolean @default(false)
  biometricEnabled Boolean @default(false)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preferences       Json?
  savedLocations    Json?
  emergencyContacts Json?

  reportedComplaints Complaint[]         @relation("ReportedComplaints")
  performedActions   ComplaintTimeline[] @relation("PerformedActions")
  assignments        Assignment[]        @relation("EngineerAssignments")
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]

  @@map("users")
}

model Otp {
  id           String   @id @default(uuid())
  email        String   @unique
  otpHash      String
  expiresAt    DateTime
  attempts     Int      @default(0)
  fullName     String?
  phoneNumber  String?
  passwordHash String?
  createdAt    DateTime @default(now())

  @@map("otps")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplaintStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  FAILED
}

model Complaint {
  id          String   @id @default(uuid())
  trackingId  String   @unique
  title       String
  description String
  category    String
  priority    Priority @default(MEDIUM)
  status      ComplaintStatus @default(PENDING)
  
  latitude    Float?
  longitude   Float?

  imageUrl    String?
  videoUrl    String?
  
  reporterId  String
  reporter    User     @relation("ReportedComplaints", fields: [reporterId], references: [id])

  assignments Assignment[]
  timeline    ComplaintTimeline[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("complaints")
}

model ComplaintTimeline {
  id          String   @id @default(uuid())
  
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  
  status      ComplaintStatus
  notes       String?
  
  performedById String
  performedBy   User     @relation("PerformedActions", fields: [performedById], references: [id])

  createdAt   DateTime @default(now())

  @@map("complaint_timelines")
}

model Assignment {
  id          String   @id @default(uuid())
  
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  
  engineerId  String
  engineer    User     @relation("EngineerAssignments", fields: [engineerId], references: [id])
  
  status      AssignmentStatus @default(ASSIGNED)
  notes       String?
  photoUrl    String?
  
  assignedAt  DateTime @default(now())
  completedAt DateTime?

  @@map("assignments")
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entity      String
  entityId    String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  details     Json?
  
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}
